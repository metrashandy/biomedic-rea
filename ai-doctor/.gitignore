# ==========================================
# 1. NODE / REACT (FRONTEND)
# ==========================================
# Abaikan folder instalasi package React
node_modules/
/dist
/build

# Abaikan logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 2. PYTHON / FASTAPI (BACKEND)
# ==========================================
# Abaikan Virtual Environment Python
venv/
.venv/
env/
ENV/

# Abaikan cache Python
__pycache__/
*.py[cod]
*$py.class

# Abaikan Database SQLite lokal kamu
clinic.db
*.db
*.sqlite3

# ==========================================
# 3. KUNCI RAHASIA & KONFIGURASI (SANGAT PENTING!)
# ==========================================
# Abaikan file .env yang berisi OpenAI API Key
.env
.env.local
.env.*.local
*.env

# ==========================================
# 4. SYSTEM FILES (OPSIONAL)
# ==========================================
.DS_Store
Thumbs.db